<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/menu_bg"
    tools:context=".MainMenu.MainMenu">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/menu_text_header"
        android:textSize="32sp"
        android:textColor="@color/text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="64dp"
        android:background="@color/background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/level_1"
                style="@style/main_menu_button"
                android:text="@string/text_button_level1"
                />

            <Button
                android:id="@+id/level_2"
                android:text="@string/text_button_level2"
                style="@style/main_menu_button"
                />

            <Button
                android:id="@+id/level_3"
                android:text="@string/text_button_level3"
                style="@style/main_menu_button"
                />

            <Button
                android:id="@+id/level_4"
                android:text="@string/text_button_level4"
                style="@style/main_menu_button"
                />

            <Button
                android:id="@+id/level_5"
                android:text="@string/text_button_level5"
                style="@style/main_menu_button"
                />

            <Button
                android:id="@+id/level_6"
                android:text="@string/text_button_level6"
                style="@style/main_menu_button"
                 />

            <Button
                android:id="@+id/level_7"
                android:text="@string/text_button_level7"
                style="@style/main_menu_button"
                />

            <Button
                android:id="@+id/level_8"
                android:text="@string/text_button_level8"
                style="@style/main_menu_button"
                />

            <Button
                android:id="@+id/level_9"
                android:text="@string/text_button_level9"
                style="@style/main_menu_button"
                />

        </LinearLayout>
    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>