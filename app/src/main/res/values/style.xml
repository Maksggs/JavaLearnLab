<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="item_manu_topics_button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">110dp</item>
        <item name="android:background">@drawable/button_topic_style</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:radius">32dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:textSize">24sp</item>
    </style>
    <style name="item_manu_topics_button_locked">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">110dp</item>
        <item name="android:background">@drawable/button_topic_style</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:textSize">24sp</item>
    </style>
    <style name="TheoryTitle">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="TheoryText">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="TheoryCode">
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/code_text</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:background">@drawable/bg_code_block</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:includeFontPadding">false</item>
    </style>
    <!-- 🔵 Текст вопроса -->
    <style name="TestQuestionText">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">20sp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- 🔘 Варианты ответов -->
    <style name="TestOptionRadio">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- ⌨️ Поля ввода -->
    <style name="TestInputField">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:backgroundTint">@color/blue</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <!-- 🔘 Кнопка -->
    <style name="TestButton">
        <item name="android:backgroundTint">@color/blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>

    <!-- 📦 Контейнер -->
    <style name="TestContainer">
        <item name="android:padding">16dp</item>
        <item name="android:background">@color/white</item>
    </style>
</resources>