<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="main_menu_button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">100dp</item>
        <item name="android:backgroundTint">@color/button_topics</item>
        <item name="android:textColor">@color/main_menu_button_text</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textSize">24sp</item>
    </style>
    <style name="button_test_type_one">
        <item name="android:layout_width">180dp</item>
        <item name="android:layout_height">100dp</item>
        <item name="android:backgroundTint">@color/button_topics</item>
        <item name="android:textColor">@color/main_menu_button_text</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginVertical">8dp</item>
    </style>
    <style name="button_exit">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/menu_bg</item>
        <item name="android:contentDescription">@string/text_exit</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:src">@drawable/arrow_exit</item>
    </style>
    <style name="theory_text_text">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/plan_text_theory</item>
    </style>
    <style name="theory_text_code">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/plan_text_theory</item>
        <item name="android:layout_width">match_parent</item>
    </style>
    <style name="test_radio_button" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:text">22sp</item>
        <item name="android:layout_marginVertical">8dp</item>
        <item name="android:background">@drawable/radio_button_background</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/plan_text_theory</item>

    </style>

</resources>