<!-- res/drawable/bg_code_block.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- фон -->
    <solid android:color="@color/code_background"/>

    <!-- скругление -->
    <corners android:radius="8dp"/>

    <!-- рамка -->
    <stroke
        android:width="1dp"
        android:color="@color/code_border"/>

    <!-- внутренние отступы -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp"/>

</shape>